# API 配置
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# 数据库配置
DATABASE_URL=sqlite:///./data/qing_agent.db

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# AI 配置（可选）
# OPENAI_API_KEY=sk-xxx
# EMBEDDING_MODEL=BAAI/bge-large-zh

# 业务配置
MAX_RECOMMEND=10
MATCH_THRESHOLD=0.7

# BOSS 直聘配置
BOSS_CITY_CODE=101280600
BOSS_EXCLUDE_DISTRICTS=宝安区

# 限流配置
SEARCH_LIMIT_PER_HOUR=10
JOB_DETAIL_LIMIT_PER_DAY=30
