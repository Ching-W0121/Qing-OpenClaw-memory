@echo off
chcp 65001 >nul
REM VectorBrain 记忆上下文加载脚本
REM 用法：load_context.cmd [关键词]

cd /d "%~dp0"

if "%1"=="" (
    echo ============================================================
    echo [VectorBrain] 加载记忆上下文...
    echo ============================================================
    python context_injector.py
) else (
    echo ============================================================
    echo [VectorBrain] 加载记忆上下文 (关键词：%*)
    echo ============================================================
    python context_injector.py %*
)

echo.
echo ============================================================
echo 记忆上下文已加载，请查看 memory/context_cache.json
echo ============================================================
pause
